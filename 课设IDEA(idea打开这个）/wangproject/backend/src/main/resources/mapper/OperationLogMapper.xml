<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.animal.mapper.OperationLogMapper">

    <resultMap id="logResultMap" type="com.animal.entity.OperationLog">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="operation" column="operation"/>
        <result property="module" column="module"/>
        <result property="method" column="method"/>
        <result property="params" column="params"/>
        <result property="ip" column="ip"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO operation_log (username, operation, module, method, params, ip, create_time)
        VALUES (#{username}, #{operation}, #{module}, #{method}, #{params}, #{ip}, #{createTime})
    </insert>

    <select id="findAll" resultMap="logResultMap">
        SELECT * FROM operation_log ORDER BY id ASC LIMIT 100
    </select>

    <!-- 分页查询 -->
    <select id="findByPage" resultMap="logResultMap">
        SELECT * FROM operation_log ORDER BY id ASC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM operation_log
    </select>
</mapper>
