<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.animal.mapper.UserMapper">

    <resultMap id="userResultMap" type="com.animal.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="role" column="role"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="findAll" resultMap="userResultMap">
        SELECT * FROM `user` ORDER BY id ASC
    </select>

    <select id="findById" resultMap="userResultMap">
        SELECT * FROM `user` WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="userResultMap">
        SELECT * FROM `user` WHERE username = #{username}
    </select>

    <insert id="insert" parameterType="com.animal.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (username, password, real_name, role)
        VALUES (#{username}, #{password}, #{realName}, #{role})
    </insert>

    <update id="update" parameterType="com.animal.entity.User">
        UPDATE `user`
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="role != null">role = #{role},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM `user` WHERE id = #{id}
    </delete>

</mapper>
